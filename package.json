{
  "name": "@commencis/starter-nextjs",
  "version": "1.1.0",
  "buildNumber": 1,
  "description": "Commencis Starter - NextJS",
  "author": "Commencis WEB Team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typegen": "next typegen",
    "analyze": "next experimental-analyze",
    "update:deps": "pnpm update --no-save",
    "lint:check:types": "tsc --noEmit",
    "lint:check:js": "eslint .",
    "lint:fix:js": "eslint . --fix",
    "lint:check:css": "stylelint **/*.{css,scss}",
    "lint:fix:css": "stylelint **/*.{css,scss} --fix",
    "lint:check:format": "prettier \"**/*.{json,md}\" --check",
    "lint:fix:format": "prettier \"**/*.{json,md}\" --write",
    "lint": "pnpm run \"/^lint:check:.*/\"",
    "lint:fix": "pnpm run \"/^lint:fix:.*/\"",
    "generate:icons": "pnpm run svgr:icons && eslint --fix src/components/icons/*.{ts,tsx}",
    "generate:vectors": "pnpm run svgr:vectors && eslint --fix src/components/vectors/**/*.{ts,tsx}",
    "svgr:icons": "svgr --config-file ./scripts/svg/icon.svgr.config.cjs src/assets/icons",
    "svgr:vectors": "svgr --config-file ./scripts/svg/vector.svgr.config.cjs src/assets/vectors",
    "ci:review": "pnpm run typegen && pnpm run lint",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install --no-frozen-lockfile",
    "bump:version": "./scripts/bump/version.sh",
    "bump:build": "./scripts/bump/build.sh",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commencis/commitlint-config": "3.4.0",
    "@commencis/eslint-config": "3.6.0",
    "@commencis/lint-staged-config": "3.1.1",
    "@commencis/prettier-config": "3.2.0",
    "@commencis/stylelint-config": "3.4.0",
    "@commitlint/cli": "20.5.0",
    "@svgr/cli": "8.1.0",
    "@svitejs/changesets-changelog-github-compact": "1.2.0",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "stylelint": "17.9.0",
    "typescript": "6.0.3"
  }
}
